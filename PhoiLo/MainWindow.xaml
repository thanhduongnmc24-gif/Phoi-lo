<Window x:Class="PhoiLo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Phôi Lò - Quản lý siêu cấp" Height="450" Width="800" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#f0f0f0">
            <TextBlock Text="MENU" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,20,0,20"/>
            <Button Content="Dữ liệu Sheet" Height="40" Margin="10,5" Click="BtnSheet_Click"/>
            <Button Content="Tính năng 2" Height="40" Margin="10,5" Click="BtnFeature2_Click"/>
        </StackPanel>

        <ContentControl x:Name="MainPanel" Grid.Column="1" Margin="10"/>
    </Grid>
</Window>