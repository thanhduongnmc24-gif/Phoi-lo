<Window x:Class="PhoiLo.Windows.SettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cài đặt nâng cao" Height="550" Width="500" WindowStartupLocation="CenterOwner">
    <ScrollViewer>
        <StackPanel Margin="20">
            <TextBlock Text="⚙ CÀI ĐẶT GIAO DIỆN" FontWeight="Bold" FontSize="18" Margin="0,0,0,15"/>

            <TextBlock Text="{Binding ColumnWidth, StringFormat='Độ rộng cột: {0:0}'}"/>
            <Slider Minimum="50" Maximum="300" Value="{Binding ColumnWidth}" Margin="0,5,0,15"/>

            <GroupBox Header="Bảng dữ liệu" Margin="0,0,0,15" Padding="10">
                <StackPanel>
                    <TextBlock Text="Font chữ:"/>
                    <ComboBox SelectedItem="{Binding TableFontFamily}" Margin="0,5">
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Segoe UI</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Arial</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Times New Roman</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Consolas</System:String>
                    </ComboBox>
                    <TextBlock Text="{Binding TableFontSize, StringFormat='Cỡ chữ: {0:0}'}" Margin="0,10,0,0"/>
                    <Slider Minimum="10" Maximum="30" Value="{Binding TableFontSize}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Danh mục (Menu)" Margin="0,0,0,15" Padding="10">
                <StackPanel>
                    <TextBlock Text="Font chữ:"/>
                    <ComboBox SelectedItem="{Binding MenuFontFamily}" Margin="0,5">
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Segoe UI</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Arial</System:String>
                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Roboto</System:String>
                    </ComboBox>
                    <TextBlock Text="{Binding MenuFontSize, StringFormat='Cỡ chữ: {0:0}'}" Margin="0,10,0,0"/>
                    <Slider Minimum="12" Maximum="24" Value="{Binding MenuFontSize}"/>
                </StackPanel>
            </GroupBox>

            <Button Content="XONG" Click="BtnClose_Click" Height="35" Background="#3498db" Foreground="White" FontWeight="Bold"/>
        </StackPanel>
    </ScrollViewer>
</Window>