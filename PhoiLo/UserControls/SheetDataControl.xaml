<UserControl x:Class="PhoiLo.UserControls.SheetDataControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="DỮ LIỆU TỪ GOOGLE SHEET" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
        
        <DataGrid x:Name="SheetDataGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
    </Grid>
</UserControl>